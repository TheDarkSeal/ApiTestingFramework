{
  "request": {
    "method": "POST",
    "url": "/auth",
    "bodyPatterns": [
      {
        "equalToJson": {
          "username": "admin",
          "password": "password123"
        }
      }
    ]
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "token": "abc123xyz456mocktoken"
    }
  }
}